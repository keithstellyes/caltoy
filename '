#include "LunarPhase.hpp"
#include <iostream>

void printYear(LunarYear ly)
{
    GregorianDate today(ly.gregorianYear, GregorianMonth::January, 1);
    for(const LunarPhase &phase : ly.getPhases()) {
        GregorianDate tmo = today.addDays(1);
        std::cout << today.month << " " << today.day;
        today = tmo;
        std::cout << to_utf8(unicodeCodepoint(phase)) << '\n';
    }
}

int main(int argc, const char *argv[])
{
    printYear(LunarYear(2026, GregorianDate(2025, GregorianMonth::December, 19)));
}
